[0.105437, "o", "\u001b[1mMnémlet v0.3 - Trust / Security / Privacy\u001b[0m\r\n\u001b[34mThrowaway demo vault: /tmp/mnemlet-demo.pqZZLg\u001b[0m\r\n\u001b[2mDemo key generated in-process and discarded on exit.\u001b[0m\r\n\r\n\u001b[33m> Starting isolated authenticated Mnémlet demo server...\u001b[0m\r\n"]
[4.164375, "o", "\u001b[32mOK Demo server running at http://127.0.0.1:14060\u001b[0m\r\n\r\n\u001b[33m> Remembering an authenticated preference...\u001b[0m\r\n"]
[4.164536, "o", "\u001b[1m$ curl -X POST http://127.0.0.1:14060/api/v1/remember -H 'X-Mnemlet-Key: ...' -d '{... preference ...}'\u001b[0m\r\n"]
[4.760397, "o", "{\r\n    \"memory_id\": \"7007281322d94ed09023864ca8d6d449\",\r\n    \"stored\": true,\r\n    \"dedup\": false,\r\n    \"namespace\": \"preferences\",\r\n    \"retention_score\": 0.45,\r\n    \"chunk_count\": 1,\r\n    "]
[4.760526, "o", "\"superseded_ids\": [],\r\n    \"contradiction_detected\": false\r\n}\r\n"]
[4.793468, "o", "\r\n\u001b[33m> Secret Guard blocks a fake test key before storage...\u001b[0m\r\n"]
[4.793588, "o", "\u001b[1m$ curl -X POST http://127.0.0.1:14060/api/v1/ingest -H 'X-Mnemlet-Key: ...' -d '{... fake key ...}'\u001b[0m\r\n"]
[4.838556, "o", "{\r\n    \"detail\": \"secret_guard_blocked: patterns=openai_key\"\r\n}\r\n"]
[4.84739, "o", "\r\n"]
[4.847474, "o", "\u001b[33m> Audit shows success and blocked security events...\u001b[0m\r\n\u001b[1m$ curl http://127.0.0.1:14060/api/v1/audit -H 'X-Mnemlet-Key: ...'\u001b[0m\r\n"]
