[0.102442, "o", "\u001b[1mMnémlet v0.3 - Trust / Security / Privacy\u001b[0m\r\n\u001b[34mThrowaway demo vault: /tmp/mnemlet-demo.4podRX\u001b[0m\r\n\u001b[2mDemo key generated in-process and discarded on exit.\u001b[0m\r\n\r\n"]
[0.103359, "o", "\u001b[33m> Starting isolated authenticated Mnémlet demo server...\u001b[0m\r\n"]
[4.174413, "o", "\u001b[32mOK Demo server running at http://127.0.0.1:14060\u001b[0m\r\n\r\n\u001b[33m> Remembering an authenticated preference...\u001b[0m\r\n"]
[4.174527, "o", "\u001b[1m$ curl -X POST http://127.0.0.1:14060/api/v1/remember -H 'Content-Type: application/json' -H 'X-Mnemlet-Key: ...' -d '{... preference ...}'\u001b[0m\r\n"]
[4.756539, "o", "{\r\n    \"memory_id\": \"4862312d922240269be45144dd7d20c5\",\r\n    \"stored\": true,\r\n    \"dedup\": false,\r\n    \"namespace\": \"preferences\",\r\n    \"retention_score\": 0.45,\r\n    \"chunk_count\": 1,\r\n    \"superseded_ids\": [],\r\n    \"contradiction_detected\": false\r\n}\r\n"]
[4.787192, "o", "\r\n\u001b[33m> Secret Guard blocks a fake test key before storage...\u001b[0m\r\n"]
[4.787318, "o", "\u001b[1m$ curl -X POST http://127.0.0.1:14060/api/v1/ingest -H 'Content-Type: application/json' -H 'X-Mnemlet-Key: ...' -d '{... fake key ...}'\u001b[0m\r\n"]
[4.83141, "o", "{\r\n    \"detail\": \"secret_guard_blocked: patterns=openai_key\"\r\n}\r\n"]
[4.839317, "o", "\r\n"]
