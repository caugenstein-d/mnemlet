[server]
host = "127.0.0.1"
port = 4050

[storage]
data_dir = "~/.mnemlet"
sqlite_path = "~/.mnemlet/mnemlet.db"
chroma_path = "~/.mnemlet/chroma"
vault_path = "~/.mnemlet/vault"

[embedding]
model = "all-MiniLM-L6-v2"
cache_dir = "~/.mnemlet/models"

[llm]
enabled = false
provider = "ollama"
model = "gemma4-e2b:q4_0"
base_url = "http://localhost:11434"
temperature = 0.3
max_tokens = 4096
unload_after_sleep = true

[search]
enabled = false
provider = "searxng"
base_url = "http://localhost:8888"
engines = ["google", "duckduckgo", "wikipedia"]
max_queries_per_sleep = 10

[intelligence]
# v0.4 intelligent memory extraction (requires [llm].enabled = true).
# Off by default; mnemlet_ingest still stores content verbatim.
extraction_enabled = false
extract_memories = true
summarize_conversations = true
inactivity_threshold_minutes = 10
max_messages = 100
