[server]
host = "127.0.0.1"
port = 4050

[storage]
data_dir = "~/.memoria"
sqlite_path = "~/.memoria/memoria.db"
chroma_path = "~/.memoria/chroma"
vault_path = "~/.memoria/vault"

[embedding]
model = "all-MiniLM-L6-v2"
cache_dir = "~/.memoria/models"

[llm]
enabled = false
provider = "ollama"
model = "gemma4-e2b:q4_0"
base_url = "http://localhost:11434"
temperature = 0.3
max_tokens = 4096
unload_after_sleep = true

[search]
enabled = false
provider = "searxng"
base_url = "http://localhost:8888"
engines = ["google", "duckduckgo", "wikipedia"]
max_queries_per_sleep = 10
